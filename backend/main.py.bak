        "status": "ok",
        "timestamp": datetime.utcnow().isoformat(),
        "dynamic_analysis": DYNAMIC_AVAILABLE,
        "version": "2.0.0",
    }


@app.get("/history")
async def history():
    """Return recent scan history (last 20 scans)."""
    return {"scans": scan_history[-20:], "total": len(scan_history)}


@app.post("/analyze")
async def analyze(file: UploadFile = File(...)):
    """
    Main APK analysis endpoint.
    Returns comprehensive security report including:
    - Static analysis (Androguard)
    - Behavioral fingerprinting
    - Dynamic analysis (Frida, if available)
    - VirusTotal hash lookup
    - AI threat narrative (Groq LLaMA 3.3 70B)
    - Risk score (0-100)
    - MITRE ATT&CK mapping
    """
    if not file.filename.endswith(".apk"):
        raise HTTPException(status_code=400, detail="Only .apk files are accepted")

    log.info(f"Scan started: {file.filename}")
    start_time = datetime.utcnow()

    # Save to temp file
    with tempfile.NamedTemporaryFile(suffix=".apk", delete=False) as tmp:
        content = await file.read()
        tmp.write(content)
        tmp_path = tmp.name

    try:
        # ── 1. Static analysis ──────────────────────────────────────────────
        log.info(f"[{file.filename}] Static analysis...")
        analysis = analyze_apk(tmp_path)

        # ── 2. Behavioral analysis (from static artifacts) ──────────────────
        log.info(f"[{file.filename}] Behavioral analysis...")
        behavioral = analyze_behavior(
            tmp_path,
            androguard_dx=analysis.get("dx"),
            analysis=analysis,
        )

        # ── 3. Dynamic analysis (Frida, optional) ──────────────────────────
        dynamic = {"status": "not_available", "findings": []}
        if DYNAMIC_AVAILABLE:
            log.info(f"[{file.filename}] Dynamic analysis (Frida)...")
            pkg = analysis.get("app_info", {}).get("package_name")
            dynamic = run_dynamic_analysis(tmp_path, pkg)
            log.info(f"[{file.filename}] Dynamic: {dynamic.get('status')} — {dynamic.get('hook_count', 0)} events")

        # ── 4. VirusTotal ───────────────────────────────────────────────────
        log.info(f"[{file.filename}] VirusTotal lookup...")
        vt = get_virustotal_result(tmp_path)
        log.info(f"[{file.filename}] VT: {vt.get('detected',0)}/{vt.get('total',0)} detected")

        # ── 5. Risk scoring ─────────────────────────────────────────────────
        log.info(f"[{file.filename}] Risk scoring...")
        score_result = calculate_score(analysis, behavioral, vt)
    risk_score = score_result.get("score", 0) if isinstance(score_result, dict) else score_result
        log.info(f"[{file.filename}] Risk score: {risk_score}/100")

        # ── 6. AI analysis ──────────────────────────────────────────────────
        log.info(f"[{file.filename}] AI analysis...")
        ai_result = get_ai_analysis(analysis, behavioral, risk_score)

        # ── 7. Build MITRE ATT&CK mapping ──────────────────────────────────
        mitre = build_mitre_mapping(analysis, behavioral)

        # ── 8. Assemble response ────────────────────────────────────────────
        elapsed = (datetime.utcnow() - start_time).total_seconds()
        log.info(f"[{file.filename}] Complete in {elapsed:.1f}s")

        result = {
            "filename":        file.filename,
            "scan_time":       datetime.utcnow().isoformat(),
            "elapsed_seconds": round(elapsed, 1),
            "risk_score":      risk_score,
            "app_info":        analysis.get("app_info", {}),
            "findings":        analysis.get("findings", []),
            "permissions":     analysis.get("permissions", {}).get("all", []),
            "behavioral":      behavioral,
            "dynamic":         dynamic,
            "virustotal":      vt,
            "ai_analysis":     ai_result,
            "mitre_mappings":  mitre,
        }

        # Store in history
        scan_history.append({
            "filename":   file.filename,
            "risk_score": risk_score,
            "scan_time":  datetime.utcnow().isoformat(),
            "package":    analysis.get("app_info", {}).get("package_name", ""),
            "vt_detected": vt.get("detected", 0),
        })

        return result

    except Exception as e:
        log.error(f"Analysis failed: {e}", exc_info=True)
        raise HTTPException(status_code=500, detail=str(e))

    finally:
        try:
            os.unlink(tmp_path)
        except Exception:
            pass


@app.post("/report")
async def generate_report(data: dict):
    """Generate PDF report from analysis results."""
    try:
        from report_generator import generate_pdf_report
        pdf_path = generate_pdf_report(data)
        return FileResponse(
            pdf_path,
            media_type="application/pdf",
            filename=f"apkguard_report_{datetime.utcnow().strftime('%Y%m%d_%H%M%S')}.pdf",
        )
    except ImportError:
        # Fallback: return JSON
        return JSONResponse(content=data)
    except Exception as e:
        log.error(f"Report generation failed: {e}")
        raise HTTPException(status_code=500, detail=str(e))


# ── MITRE ATT&CK mapping logic ─────────────────────────────────────────────────

MITRE_RULES = [
    # (technique_id, name, tactic, trigger_fn)
    ("T1407", "Download New Code at Runtime",     "Defense Evasion",        lambda a, b: _api(a, "DexClassLoader")),
    ("T1406", "Obfuscated Files or Information",  "Defense Evasion",        lambda a, b: _api(a, "Reflection") or _api(a, "invoke")),
    ("T1432", "Access Contact List",              "Collection",             lambda a, b: _perm(a, "READ_CONTACTS")),
    ("T1412", "Capture SMS Messages",             "Collection",             lambda a, b: _perm(a, "READ_SMS") or _perm(a, "RECEIVE_SMS")),
    ("T1430", "Location Tracking",               "Collection",             lambda a, b: _perm(a, "ACCESS_FINE_LOCATION")),
    ("T1418", "Software Discovery",              "Discovery",              lambda a, b: _api(a, "PackageManager")),
    ("T1437", "Standard Application Layer Protocol", "Command and Control", lambda a, b: _api(a, "HttpURLConnection") or _api(a, "OkHttp")),
    ("T1438", "Alternate Network Mediums",       "Exfiltration",           lambda a, b: _perm(a, "SEND_SMS") and _perm(a, "INTERNET")),
    ("T1456", "Drive-by Compromise",            "Initial Access",          lambda a, b: _api(a, "WebView") and _api(a, "loadUrl")),
    ("T1409", "Stored Application Data",        "Collection",             lambda a, b: _api(a, "SQLiteDatabase") or _api(a, "SharedPreferences")),
    ("T1417", "Input Capture",                 "Collection",             lambda a, b: _bhv(b, "Accessibility") or _bhv(b, "Overlay")),
    ("T1411", "User Interface Deception",       "Credential Access",      lambda a, b: _bhv(b, "Banking Overlay")),
    ("T1508", "Suppress Application Icon",      "Defense Evasion",        lambda a, b: _manifest(a, "LAUNCHER") == False),
    ("T1516", "Input Injection",               "Impact",                 lambda a, b: _api(a, "AccessibilityService")),
    ("T1481", "Web Service",                   "Command and Control",    lambda a, b: _str(a, "firebase") or _str(a, "googleapis")),
]


def _perm(analysis: dict, perm: str) -> bool:
    perms = analysis.get("permissions", {})
    all_perms = perms.get("all", []) if isinstance(perms, dict) else []
    dangerous  = [p.get("permission","") for p in perms.get("dangerous", [])] if isinstance(perms, dict) else []
    combined = " ".join(all_perms + dangerous)
    return perm in combined


def _api(analysis: dict, api: str) -> bool:
    apis = analysis.get("suspicious_apis", [])
    for a in apis:
        if isinstance(a, str) and api.lower() in a.lower():
            return True
        if isinstance(a, dict) and api.lower() in str(a).lower():
            return True
    return False


def _bhv(behavioral: dict, keyword: str) -> bool:
    behaviors = behavioral.get("dynamic_behaviors", [])
    for b in behaviors:
        if keyword.lower() in str(b).lower():
            return True
    return False


def _str(analysis: dict, keyword: str) -> bool:
    strings = analysis.get("suspicious_strings", [])
    return any(keyword.lower() in str(s).lower() for s in strings)


def _manifest(analysis: dict, key: str):
    return analysis.get("manifest", {}).get(key)


def build_mitre_mapping(analysis: dict, behavioral: dict) -> list:
    mapping = []
    for tech_id, name, tactic, trigger in MITRE_RULES:
        try:
            if trigger(analysis, behavioral):
                mapping.append({
                    "technique_id": tech_id,
                    "name":         name,
                    "tactic":       tactic,
                    "confidence":   round(0.65 + (hash(tech_id) % 35) / 100, 2),
                })
        except Exception:
            pass
    return mapping


