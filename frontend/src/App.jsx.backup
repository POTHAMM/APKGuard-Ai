import { useState, useCallback } from 'react'
import axios from 'axios'
import './App.css'

const API = 'http://localhost:8000'

const severityColor = (s) => {
  if (!s) return '#00ffff'
  const sl = s.toLowerCase()
  if (sl === 'critical') return '#ff0000'
  if (sl === 'high') return '#ff6600'
  if (sl === 'medium') return '#ffaa00'
  return '#00ff88'
}

const severityBg = (s) => {
  if (!s) return 'rgba(0,255,255,0.1)'
  const sl = s.toLowerCase()
  if (sl === 'critical') return 'rgba(255,0,0,0.15)'
  if (sl === 'high') return 'rgba(255,102,0,0.15)'
  if (sl === 'medium') return 'rgba(255,170,0,0.15)'
  return 'rgba(0,255,136,0.15)'
}

function RiskGauge({ score, severity }) {
  const r = 80, cx = 100, cy = 100
  const circ = 2 * Math.PI * r
  const pct = Math.min(Math.max(score || 0, 0), 100) / 100
  const dash = pct * circ
  const color = severityColor(severity)
  return (
    <div style={{ textAlign: 'center' }}>
      <svg width="200" height="200" viewBox="0 0 200 200">
        <circle cx={cx} cy={cy} r={r} fill="none" stroke="#1a1a2e" strokeWidth="16"/>
        <circle cx={cx} cy={cy} r={r} fill="none" stroke={color} strokeWidth="16"
          strokeDasharray={`${dash} ${circ}`} strokeLinecap="round"
          transform="rotate(-90 100 100)" style={{ transition: 'stroke-dasharray 1s ease' }}/>
        <text x="100" y="90" textAnchor="middle" fill={color}
          style={{ fontSize: '36px', fontWeight: 'bold', fontFamily: 'monospace' }}>
          {score || 0}
        </text>
        <text x="100" y="115" textAnchor="middle" fill="#aaa"
          style={{ fontSize: '12px', fontFamily: 'monospace' }}>/100</text>
        <text x="100" y="140" textAnchor="middle" fill={color}
          style={{ fontSize: '14px', fontWeight: 'bold', fontFamily: 'monospace' }}>
          {severity || 'UNKNOWN'}
        </text>
      </svg>
    </div>
  )
}

function FindingCard({ finding }) {
  const [open, setOpen] = useState(false)
  const color = severityColor(finding.severity)
  const bg = severityBg(finding.severity)
  return (
    <div onClick={() => setOpen(!open)} style={{
      background: bg, border: `1px solid ${color}40`,
      borderLeft: `3px solid ${color}`, borderRadius: '6px',
      padding: '12px 16px', cursor: 'pointer', marginBottom: '8px',
      transition: 'all 0.2s'
    }}>
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
        <span style={{ color: '#e0e0e0', fontWeight: '600', fontSize: '14px' }}>{finding.title}</span>
        <span style={{
          color, fontSize: '11px', fontWeight: 'bold',
          background: `${color}20`, padding: '2px 8px', borderRadius: '4px'
        }}>{finding.severity?.toUpperCase()}</span>
      </div>
      {open && (
        <p style={{ color: '#aaa', fontSize: '13px', marginTop: '8px', lineHeight: '1.5' }}>
          {finding.explanation}
        </p>
      )}
    </div>
  )
}
function UploadPage({ onResult, loading, setLoading }) {
  const [drag, setDrag] = useState(false)
  const [progress, setProgress] = useState(0)
  const [error, setError] = useState('')

  const analyze = async (file) => {
    if (!file?.name.endsWith('.apk')) { setError('Only .apk files accepted'); return }
    setError(''); setLoading(true); setProgress(10)
    const fd = new FormData()
    fd.append('file', file)
    try {
      setProgress(30)
      const res = await axios.post(`${API}/analyze`, fd, {
        headers: { 'Content-Type': 'multipart/form-data' },
        onUploadProgress: (e) => setProgress(Math.round(30 + (e.loaded/e.total)*40)),
      })
      setProgress(90)
      setTimeout(() => { setProgress(100); onResult(res.data) }, 500)
    } catch (e) {
      setError(e.response?.data?.detail || 'Analysis failed. Check backend.')
      setLoading(false); setProgress(0)
    }
  }

  const onDrop = useCallback((e) => {
    e.preventDefault(); setDrag(false)
    const file = e.dataTransfer.files[0]
    if (file) analyze(file)
  }, [])

  return (
    <div style={{ minHeight: '100vh', background: '#0a0a0f', display: 'flex',
      flexDirection: 'column', alignItems: 'center', justifyContent: 'center', padding: '20px' }}>
      <div style={{ marginBottom: '40px', textAlign: 'center' }}>
        <h1 style={{ color: '#00ffff', fontFamily: 'monospace', fontSize: '2.5rem',
          fontWeight: 'bold', margin: 0, textShadow: '0 0 20px #00ffff80' }}>
          APKGuard AI
        </h1>
        <p style={{ color: '#666', fontFamily: 'monospace', marginTop: '8px' }}>
          Generative AI-Powered Android Malware Analysis
        </p>
      </div>

      <div onDragOver={(e) => { e.preventDefault(); setDrag(true) }}
        onDragLeave={() => setDrag(false)} onDrop={onDrop}
        style={{
          width: '100%', maxWidth: '500px', border: `2px dashed ${drag ? '#00ffff' : '#333'}`,
          borderRadius: '12px', padding: '60px 40px', textAlign: 'center',
          background: drag ? 'rgba(0,255,255,0.05)' : '#0d0d1a',
          cursor: 'pointer', transition: 'all 0.3s',
          boxShadow: drag ? '0 0 30px rgba(0,255,255,0.2)' : 'none'
        }}
        onClick={() => document.getElementById('apk-input').click()}>
        <div style={{ fontSize: '48px', marginBottom: '16px' }}>🛡️</div>
        <p style={{ color: '#00ffff', fontFamily: 'monospace', fontSize: '16px', margin: '0 0 8px' }}>
          {loading ? 'Analyzing...' : 'Drop APK file here'}
        </p>
        <p style={{ color: '#555', fontFamily: 'monospace', fontSize: '12px' }}>
          or click to browse • max 50MB
        </p>
        <input id="apk-input" type="file" accept=".apk" style={{ display: 'none' }}
          onChange={(e) => { if (e.target.files[0]) analyze(e.target.files[0]) }}/>
      </div>

      {loading && (
        <div style={{ width: '100%', maxWidth: '500px', marginTop: '24px' }}>
          <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: '6px' }}>
            <span style={{ color: '#666', fontFamily: 'monospace', fontSize: '12px' }}>
              {progress < 40 ? 'Uploading...' : progress < 80 ? 'Analyzing APK...' : 'Getting AI analysis...'}
            </span>
            <span style={{ color: '#00ffff', fontFamily: 'monospace', fontSize: '12px' }}>{progress}%</span>
          </div>
          <div style={{ background: '#1a1a2e', borderRadius: '4px', height: '6px' }}>
            <div style={{ background: '#00ffff', height: '6px', borderRadius: '4px',
              width: `${progress}%`, transition: 'width 0.3s',
              boxShadow: '0 0 10px #00ffff' }}/>
          </div>
        </div>
      )}

      {error && (
        <div style={{ marginTop: '16px', color: '#ff4444', fontFamily: 'monospace',
          fontSize: '13px', background: 'rgba(255,68,68,0.1)',
          padding: '10px 16px', borderRadius: '6px', border: '1px solid #ff444440' }}>
          ⚠ {error}
        </div>
      )}
    </div>
  )
}
function ResultsDashboard({ data, onReset }) {
  const score = data?.score || {}
  const appInfo = data?.app_info || {}
  const fileInfo = data?.file_info || {}
  const ai = data?.ai_analysis || {}
  const perms = data?.permissions?.dangerous || []
  const apis = data?.suspicious_apis || []
  const urls = data?.urls_ips?.urls || []
  const ips = data?.urls_ips?.ips || []
  const obf = data?.obfuscation || {}
  const mitre = ai?.mitre_techniques || score?.mitre || []
  const findings = ai?.findings || []
  const recommendations = ai?.recommendations || []

  const downloadReport = () => {
  const ai = data?.ai_analysis || {}
  const score = data?.score || {}
  const perms = data?.permissions?.dangerous || []
  const mitre = ai?.mitre_techniques || []
  const text = `
APKGUARD AI - THREAT INTELLIGENCE REPORT
==========================================
Scan ID    : ${data.scan_id}
Timestamp  : ${new Date(data.timestamp).toLocaleString()}
File       : ${data.file_info?.filename}
MD5        : ${data.file_info?.md5}
SHA256     : ${data.file_info?.sha256}

RISK ASSESSMENT
---------------
Score      : ${score.score}/100
Severity   : ${score.severity}
Family     : ${ai.malware_family}
Confidence : ${ai.confidence}

THREAT SUMMARY
--------------
${ai.threat_summary}

ANALYST NOTE
------------
${ai.analyst_note}

DANGEROUS PERMISSIONS (${perms.length})
-------------------------------
${perms.map(p => `• ${p.permission.split('.').pop()}: ${p.reason}`).join('\n')}

AI FINDINGS
-----------
${(ai.findings || []).map(f => `[${f.severity?.toUpperCase()}] ${f.title}\n  ${f.explanation}`).join('\n\n')}

MITRE ATT&CK MAPPING
--------------------
${mitre.map(m => `• ${m.id} - ${m.name}: ${m.description}`).join('\n')}

RECOMMENDATIONS
---------------
${(ai.recommendations || []).map((r, i) => `${i+1}. ${r}`).join('\n')}

SCORE BREAKDOWN
---------------
${(score.breakdown || []).map(b => `• ${b.category}: +${b.points} (${b.detail})`).join('\n')}

--
Generated by APKGuard AI | ${new Date().toLocaleString()}
`.trim()

  const blob = new Blob([text], { type: 'text/plain' })
  const url = URL.createObjectURL(blob)
  const a = document.createElement('a')
  a.href = url
  a.download = `APKGuard_${data.scan_id}_report.txt`
  a.click()
}

  return (
    <div style={{ minHeight: '100vh', background: '#0a0a0f', padding: '20px', fontFamily: 'monospace' }}>
      <div style={{ maxWidth: '1200px', margin: '0 auto' }}>

        {/* Header */}
        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '24px' }}>
          <div>
            <h1 style={{ color: '#00ffff', margin: 0, fontSize: '1.8rem', textShadow: '0 0 20px #00ffff60' }}>
              APKGuard AI
            </h1>
            <p style={{ color: '#555', margin: '4px 0 0', fontSize: '12px' }}>
              Scan ID: {data.scan_id} • {new Date(data.timestamp).toLocaleString()}
            </p>
          </div>
          <div style={{ display: 'flex', gap: '12px' }}>
            <button onClick={downloadReport} style={{
              background: 'rgba(0,255,255,0.1)', border: '1px solid #00ffff40',
              color: '#00ffff', padding: '8px 16px', borderRadius: '6px',
              cursor: 'pointer', fontSize: '13px' }}>
              ⬇ Download Report
            </button>
            <button onClick={onReset} style={{
              background: 'rgba(255,255,255,0.05)', border: '1px solid #333',
              color: '#aaa', padding: '8px 16px', borderRadius: '6px',
              cursor: 'pointer', fontSize: '13px' }}>
              ← New Scan
            </button>
          </div>
        </div>

        {/* Top row: Risk Gauge + App Info + AI Summary */}
        <div style={{ display: 'grid', gridTemplateColumns: '200px 1fr 1fr', gap: '16px', marginBottom: '16px' }}>
          <div style={{ background: '#0d0d1a', border: '1px solid #1a1a2e', borderRadius: '10px', padding: '16px', display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
            <RiskGauge score={score.score} severity={score.severity} />
          </div>

          <div style={{ background: '#0d0d1a', border: '1px solid #1a1a2e', borderRadius: '10px', padding: '20px' }}>
            <h3 style={{ color: '#00ffff', margin: '0 0 12px', fontSize: '13px', textTransform: 'uppercase', letterSpacing: '1px' }}>App Information</h3>
            {[
              ['App Name', appInfo.app_name],
              ['Package', appInfo.package],
              ['Version', appInfo.version_name],
              ['Target SDK', appInfo.target_sdk],
              ['File Size', `${fileInfo.size_kb} KB`],
              ['MD5', fileInfo.md5?.substring(0,16) + '...'],
            ].map(([k, v]) => (
              <div key={k} style={{ display: 'flex', justifyContent: 'space-between', marginBottom: '6px', fontSize: '12px' }}>
                <span style={{ color: '#555' }}>{k}</span>
                <span style={{ color: '#e0e0e0', maxWidth: '200px', textAlign: 'right', wordBreak: 'break-all' }}>{v || 'N/A'}</span>
              </div>
            ))}
          </div>

          <div style={{ background: '#0d0d1a', border: `1px solid ${severityColor(score.severity)}40`, borderRadius: '10px', padding: '20px' }}>
            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '12px' }}>
              <h3 style={{ color: '#00ffff', margin: 0, fontSize: '13px', textTransform: 'uppercase', letterSpacing: '1px' }}>AI Threat Summary</h3>
              <span style={{ fontSize: '11px', color: severityColor(score.severity), background: `${severityColor(score.severity)}20`, padding: '2px 8px', borderRadius: '4px' }}>
                {ai.malware_family || 'Unknown'}
              </span>
            </div>
            <p style={{ color: '#ccc', fontSize: '13px', lineHeight: '1.6', margin: '0 0 12px' }}>
              {ai.threat_summary || 'Analysis pending...'}
            </p>
            <p style={{ color: '#888', fontSize: '12px', fontStyle: 'italic', margin: 0, borderTop: '1px solid #1a1a2e', paddingTop: '10px' }}>
              💡 {ai.analyst_note || ''}
            </p>
          </div>
        </div>

        {/* Score Breakdown */}
        {score.breakdown?.length > 0 && (
          <div style={{ background: '#0d0d1a', border: '1px solid #1a1a2e', borderRadius: '10px', padding: '20px', marginBottom: '16px' }}>
            <h3 style={{ color: '#00ffff', margin: '0 0 16px', fontSize: '13px', textTransform: 'uppercase', letterSpacing: '1px' }}>Risk Score Breakdown</h3>
            <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(200px, 1fr))', gap: '12px' }}>
              {score.breakdown.map((b, i) => (
                <div key={i} style={{ background: '#0a0a0f', borderRadius: '8px', padding: '12px' }}>
                  <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: '6px' }}>
                    <span style={{ color: '#aaa', fontSize: '12px' }}>{b.category}</span>
                    <span style={{ color: '#00ffff', fontSize: '12px', fontWeight: 'bold' }}>+{b.points}</span>
                  </div>
                  <div style={{ background: '#1a1a2e', borderRadius: '3px', height: '4px' }}>
                    <div style={{ background: '#00ffff', height: '4px', borderRadius: '3px', width: `${Math.min(b.points * 3, 100)}%` }}/>
                  </div>
                  <p style={{ color: '#555', fontSize: '11px', margin: '6px 0 0' }}>{b.detail}</p>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* Findings + Permissions */}
        <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '16px', marginBottom: '16px' }}>
          <div style={{ background: '#0d0d1a', border: '1px solid #1a1a2e', borderRadius: '10px', padding: '20px' }}>
            <h3 style={{ color: '#00ffff', margin: '0 0 16px', fontSize: '13px', textTransform: 'uppercase', letterSpacing: '1px' }}>
              AI Findings ({findings.length})
            </h3>
            {findings.length > 0 ? findings.map((f, i) => <FindingCard key={i} finding={f} />) :
              <p style={{ color: '#555', fontSize: '13px' }}>No findings reported.</p>}
          </div>

          <div style={{ background: '#0d0d1a', border: '1px solid #1a1a2e', borderRadius: '10px', padding: '20px' }}>
            <h3 style={{ color: '#00ffff', margin: '0 0 16px', fontSize: '13px', textTransform: 'uppercase', letterSpacing: '1px' }}>
              Dangerous Permissions ({perms.length})
            </h3>
            <div style={{ maxHeight: '300px', overflowY: 'auto' }}>
              {perms.map((p, i) => (
                <div key={i} style={{ borderBottom: '1px solid #1a1a2e', paddingBottom: '8px', marginBottom: '8px' }}>
                  <div style={{ color: '#ff6600', fontSize: '12px', fontWeight: 'bold' }}>
                    {p.permission?.split('.').pop()}
                  </div>
                  <div style={{ color: '#888', fontSize: '11px', marginTop: '2px' }}>{p.reason}</div>
                </div>
              ))}
              {perms.length === 0 && <p style={{ color: '#555', fontSize: '13px' }}>No dangerous permissions.</p>}
            </div>
          </div>
        </div>

        {/* MITRE ATT&CK */}
        {mitre.length > 0 && (
          <div style={{ background: '#0d0d1a', border: '1px solid #1a1a2e', borderRadius: '10px', padding: '20px', marginBottom: '16px' }}>
            <h3 style={{ color: '#00ffff', margin: '0 0 16px', fontSize: '13px', textTransform: 'uppercase', letterSpacing: '1px' }}>
              MITRE ATT&CK Mobile Mapping
            </h3>
            <div style={{ overflowX: 'auto' }}>
              <table style={{ width: '100%', borderCollapse: 'collapse', fontSize: '13px' }}>
                <thead>
                  <tr style={{ borderBottom: '1px solid #1a1a2e' }}>
                    {['Technique ID', 'Name', 'Description'].map(h => (
                      <th key={h} style={{ color: '#555', textAlign: 'left', padding: '8px 12px', fontWeight: 'normal', fontSize: '11px', textTransform: 'uppercase' }}>{h}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {mitre.map((m, i) => (
                    <tr key={i} style={{ borderBottom: '1px solid #0a0a0f' }}>
                      <td style={{ padding: '10px 12px', color: '#00ffff', fontWeight: 'bold' }}>{m.id}</td>
                      <td style={{ padding: '10px 12px', color: '#e0e0e0' }}>{m.name}</td>
                      <td style={{ padding: '10px 12px', color: '#888', fontSize: '12px' }}>{m.description || m.tactic}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

        {/* Recommendations */}
        {recommendations.length > 0 && (
          <div style={{ background: '#0d0d1a', border: '1px solid #1a1a2e', borderRadius: '10px', padding: '20px' }}>
            <h3 style={{ color: '#00ffff', margin: '0 0 16px', fontSize: '13px', textTransform: 'uppercase', letterSpacing: '1px' }}>
              Recommendations
            </h3>
            {recommendations.map((r, i) => (
              <div key={i} style={{ display: 'flex', gap: '12px', marginBottom: '10px', alignItems: 'flex-start' }}>
                <span style={{ color: '#00ffff', fontWeight: 'bold', minWidth: '20px' }}>{i + 1}.</span>
                <span style={{ color: '#ccc', fontSize: '13px', lineHeight: '1.5' }}>{r}</span>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  )
}
export default function App() {
  const [result, setResult] = useState(null)
  const [loading, setLoading] = useState(false)

  const handleResult = (data) => {
    setLoading(false)
    setResult(data)
  }

  if (result) {
    return <ResultsDashboard data={result} onReset={() => setResult(null)} />
  }

  return (
    <UploadPage
      onResult={handleResult}
      loading={loading}
      setLoading={setLoading}
    />
  )
}
